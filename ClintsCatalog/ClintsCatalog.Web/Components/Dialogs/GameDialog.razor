<MudDialog Style="background-color: #2a2a2a; border: 1px solid #3a3020;">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color:#f5a623; font-family:'Courier New',monospace; letter-spacing:2px; text-transform:uppercase;">
            @Title
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack>
            <MudTextField @bind-Value="_model.Title" Label="Title" Required="true"
                          RequiredError="Title is required."
                          Style="color:#e8d5b0;" />
            <MudTextField @bind-Value="_model.Publisher" Label="Publisher" Required="true"
                          RequiredError="Publisher is required."
                          Style="color:#e8d5b0;" />
            <MudTextField @bind-Value="_model.Developer" Label="Developer" Required="true"
                          RequiredError="Developer is required."
                          Style="color:#e8d5b0;" />
            <MudTextField @bind-Value="_model.Barcode" Label="Barcode"
                          Style="color:#e8d5b0;" />
            <MudSelect @bind-Value="_model.Media" Label="Media"
                       Style="color:#e8d5b0;">
                @foreach (MediaType media in Enum.GetValues(typeof(MediaType)))
                {
                    <MudSelectItem Value="@media">@media</MudSelectItem>
                }
            </MudSelect>
            <MudSelect @bind-Value="_model.Packaging" Label="Packaging"
                       Style="color:#e8d5b0;">
                @foreach (PackagingType packaging in Enum.GetValues(typeof(PackagingType)))
                {
                    <MudSelectItem Value="@packaging">@packaging</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Style="color:#a89070; font-family:'Courier New',monospace;">
            Cancel
        </MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Style="font-family:'Courier New',monospace; font-weight:bold;">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>
